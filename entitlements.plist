<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Network access for BLE simulation and updates -->
    <key>com.apple.security.network.client</key>
    <true/>
    
    <!-- Network server for local development/testing -->
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- File system access for configuration and logs -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Bluetooth access for real ring connectivity -->
    <key>com.apple.security.device.bluetooth</key>
    <true/>
    
    <!-- USB access for potential future hardware connections -->
    <key>com.apple.security.device.usb</key>
    <true/>
    
    <!-- Camera access if needed for future AR features -->
    <key>com.apple.security.device.camera</key>
    <false/>
    
    <!-- Microphone access if needed for future audio features -->
    <key>com.apple.security.device.audio-input</key>
    <false/>
    
    <!-- Disable App Sandbox for development tool -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    
    <!-- Allow JIT compilation for performance -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    
    <!-- Allow unsigned executable memory for Rust/WASM -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    
    <!-- Disable library validation for development -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    
    <!-- Hardened runtime compatibility -->
    <key>com.apple.security.cs.debugger</key>
    <false/>
</dict>
</plist>
